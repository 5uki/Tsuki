---
import Default from '@/layouts/Default.astro'
import { t } from '@/config/tsuki-config'

export const prerender = true

const aboutMd = await import('../../../../contents/about.md')
const { Content } = aboutMd
---

<Default title={t('page.about')} description={t('page.aboutDesc')}>
  <article class="tsuki-content-card about-page">
    <h1 class="about-title">{t('page.about')}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
</Default>

<style>
  .about-title {
    margin-bottom: var(--tsuki-space-2xl);
    padding-bottom: var(--tsuki-space-lg);
    border-bottom: 1px solid var(--tsuki-surface-border);
    font-size: var(--tsuki-text-3xl);
    font-weight: 600;
    line-height: var(--tsuki-line-height-heading);
    color: var(--tsuki-fg);
  }
</style>
