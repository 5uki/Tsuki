---
import Base from '@/layouts/Base.astro'
import Header from '@/components/layout/Header.astro'
import { t } from '@/config/tsuki-config'

export const prerender = true
---

<Base title={t('error.404.title')} noindex>
  <Header />
  <main class="error-page">
    <div class="error-card">
      <span class="error-code">404</span>
      <h1 class="error-title">{t('error.404.title')}</h1>
      <p class="error-desc">{t('error.404.desc')}</p>
      <a href="/" class="error-back">{t('error.404.back')}</a>
    </div>
  </main>
</Base>

<style>
  .error-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: var(--tsuki-space-xl);
  }

  .error-card {
    text-align: center;
    max-width: 24rem;
  }

  .error-code {
    display: block;
    font-size: 6rem;
    font-weight: 800;
    line-height: 1;
    color: var(--tsuki-theme-accent);
    opacity: 0.25;
    margin-bottom: var(--tsuki-space-md);
  }

  .error-title {
    font-size: var(--tsuki-text-2xl);
    font-weight: 600;
    color: var(--tsuki-fg);
    margin: 0 0 var(--tsuki-space-sm);
  }

  .error-desc {
    font-size: var(--tsuki-text-sm);
    color: var(--tsuki-muted-fg);
    margin: 0 0 var(--tsuki-space-xl);
    line-height: 1.6;
  }

  .error-back {
    display: inline-flex;
    align-items: center;
    gap: var(--tsuki-space-xs);
    padding: var(--tsuki-space-sm) var(--tsuki-space-lg);
    border-radius: var(--tsuki-radius-md);
    background: var(--tsuki-theme-accent);
    color: var(--tsuki-color-on-primary);
    font-size: var(--tsuki-text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: opacity 150ms;
  }

  .error-back:hover {
    opacity: 0.85;
  }
</style>
