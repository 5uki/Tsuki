---
import { t } from '@/config/tsuki-config'
import { socialIconNames } from '@tsuki/shared/icons'

interface Props {
  url: string
  title: string
  description?: string
}

const { url, title, description = '' } = Astro.props

const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
const encodedDesc = encodeURIComponent(description)

const platforms = [
  {
    name: 'X',
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
    icon: socialIconNames['fa6-brands:x-twitter'],
  },
  {
    name: '微博',
    href: `https://service.weibo.com/share/share.php?url=${encodedUrl}&title=${encodedTitle}`,
    icon: socialIconNames['fa6-brands:weibo'],
  },
  {
    name: 'QQ',
    href: `https://connect.qq.com/widget/shareqq/index.html?url=${encodedUrl}&title=${encodedTitle}&desc=${encodedDesc}`,
    icon: socialIconNames['fa6-brands:qq'],
  },
  {
    name: 'Telegram',
    href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
    icon: socialIconNames['fa6-brands:telegram'],
  },
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
    icon: 'https://cdn.simpleicons.org/linkedin',
  },
]
---

<div class="share-buttons">
  <span class="share-label">{t('share.title')}</span>
  <div class="share-icons">
    {
      platforms.map((p) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="share-btn"
          aria-label={p.name}
          title={p.name}
        >
          <img src={p.icon} alt="" loading="lazy" decoding="async" class="share-icon-img" />
        </a>
      ))
    }
    <button
      class="share-btn share-wechat-btn"
      aria-label="WeChat"
      title="WeChat"
      data-share-url={url}
    >
      <img src={socialIconNames['fa6-brands:weixin']} alt="" class="share-icon-img" />
    </button>
    <button
      class="share-btn share-copy-btn"
      aria-label={t('share.copyLink')}
      title={t('share.copyLink')}
      data-share-url={url}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path
          d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
        ></path>
      </svg>
    </button>
  </div>
</div>

<div class="share-wechat-popup" id="share-wechat-popup" style="display:none;">
  <div class="share-wechat-overlay" data-close-wechat></div>
  <div class="share-wechat-card">
    <p class="share-wechat-tip">{t('share.wechatTip')}</p>
    <canvas id="share-qr-canvas" width="200" height="200"></canvas>
    <button class="share-wechat-close" data-close-wechat>&times;</button>
  </div>
</div>

<script>
  function initShareButtons() {
    // Copy link
    document.querySelectorAll<HTMLButtonElement>('.share-copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          btn.classList.add('copied')
          setTimeout(() => btn.classList.remove('copied'), 2000)
        } catch {
          // fallback
        }
      })
    })

    // WeChat QR popup
    document.querySelectorAll<HTMLButtonElement>('.share-wechat-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.shareUrl
        const popup = document.getElementById('share-wechat-popup')
        const canvas = document.getElementById('share-qr-canvas') as HTMLCanvasElement | null
        if (!url || !popup || !canvas) return

        popup.style.display = 'flex'

        try {
          const qrcode = (await import('qrcode-generator')).default
          const qr = qrcode(0, 'M')
          qr.addData(url)
          qr.make()

          const ctx = canvas.getContext('2d')
          if (!ctx) return
          const size = 200
          const cellSize = size / qr.getModuleCount()
          ctx.fillStyle = '#ffffff'
          ctx.fillRect(0, 0, size, size)
          ctx.fillStyle = '#000000'
          for (let r = 0; r < qr.getModuleCount(); r++) {
            for (let c = 0; c < qr.getModuleCount(); c++) {
              if (qr.isDark(r, c)) {
                ctx.fillRect(c * cellSize, r * cellSize, cellSize, cellSize)
              }
            }
          }
        } catch {
          // qrcode-generator not available
        }
      })
    })

    document.querySelectorAll('[data-close-wechat]').forEach((el) => {
      el.addEventListener('click', () => {
        const popup = document.getElementById('share-wechat-popup')
        if (popup) popup.style.display = 'none'
      })
    })
  }

  initShareButtons()
  document.addEventListener('astro:page-load', initShareButtons)
</script>

<style>
  .share-buttons { display:flex; align-items:center; gap:var(--tsuki-space-md); margin-top:var(--tsuki-space-2xl); padding-top:var(--tsuki-space-lg); border-top:1px solid var(--tsuki-surface-border); }
  .share-label { font-size:var(--tsuki-text-sm); font-weight:500; color:var(--tsuki-muted-fg); white-space:nowrap; }
  .share-icons { display:flex; gap:var(--tsuki-space-xs); flex-wrap:wrap; }
  .share-btn { display:inline-flex; align-items:center; justify-content:center; width:2rem; height:2rem; border-radius:var(--tsuki-radius-md); background:var(--tsuki-surface-muted-soft); border:1px solid var(--tsuki-surface-border); color:var(--tsuki-muted-fg); text-decoration:none; cursor:pointer; transition:color 150ms, background-color 150ms, border-color 150ms; font-family:inherit; }
  .share-btn:hover { color:var(--tsuki-theme-accent); border-color:color-mix(in srgb, var(--tsuki-theme-accent) 40%, transparent); background:color-mix(in srgb, var(--tsuki-theme-accent) 8%, transparent); }
  .share-icon-img { width: 16px; height: 16px; filter: grayscale(1) contrast(0.9); opacity: 0.9; }
  .share-btn:hover .share-icon-img { filter: none; opacity: 1; }
  .share-copy-btn.copied { color: var(--tsuki-theme-accent); border-color: var(--tsuki-theme-accent); }
  .share-wechat-popup { position: fixed; inset: 0; z-index: 200; display: flex; align-items: center; justify-content: center; }
  .share-wechat-overlay { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.5); }
  .share-wechat-card { position: relative; background: var(--tsuki-sidebar-card-bg); border-radius: var(--tsuki-radius-lg); padding: var(--tsuki-space-xl); text-align: center; box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2); }
  .share-wechat-tip { margin: 0 0 var(--tsuki-space-md); font-size: var(--tsuki-text-sm); color: var(--tsuki-muted-fg); }
  .share-wechat-close { position: absolute; top: var(--tsuki-space-sm); right: var(--tsuki-space-sm); width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; background: none; border: none; color: var(--tsuki-muted-fg); font-size: 1.2rem; cursor: pointer; }
</style>
