---
// 顶部导航栏组件
import { THEME_METAS } from '@tsuki/shared/theme'
import { uiIcons } from '@tsuki/shared/icons'
import tsukiConfig, { t } from '@/config/tsuki-config'
import type { NavLink } from '@tsuki/config'
import NotificationBell from '@/components/notifications/NotificationBell'

const navLinks: NavLink[] = tsukiConfig.nav ?? []
const siteTitle = tsukiConfig.site.title
const searchI18nData = JSON.stringify({
  loading: t('header.searchLoading'),
  noResults: t('header.searchNoResults'),
  noTitle: t('header.searchNoTitle'),
  error: t('header.searchError'),
})
const notifI18n = {
  title: t('notification.title'),
  empty: t('notification.empty'),
  markAllRead: t('notification.markAllRead'),
  commentReply: t('notification.commentReply'),
  commentPinned: t('notification.commentPinned'),
  commentHidden: t('notification.commentHidden'),
  commentDeleted: t('notification.commentDeleted'),
}
---

<header class="header" data-search-i18n={searchI18nData}>
  <div class="header-inner">
    <div class="header-track">
      <div class="header-pill header-brand">
        <a href="/" class="logo">
          <img src="/favicon.svg" alt="" class="logo-favicon" width="22" height="22" />
          <span class="logo-text">{siteTitle}</span>
        </a>
      </div>

      <nav class="header-pill nav">
        {
          navLinks.map((link) => (
            <a href={link.href}>
              {link.icon && <span class="nav-icon" set:html={link.icon} />}
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="header-pill actions">
        <div class="mobile-left">
          <a href="/" class="logo mobile-logo">
            <img src="/favicon.svg" alt="" class="logo-favicon" width="20" height="20" />
            <span class="logo-text">{siteTitle}</span>
          </a>
        </div>

        <div class="search-area">
          <button class="action-btn search-btn" id="search-toggle" aria-label={t('header.search')}>
            <span set:html={uiIcons.search} />
          </button>
          <div id="search-dropdown" class="search-dropdown">
            <div class="search-dd-header">
              <svg
                class="search-dd-icon"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg
              >
              <input
                type="search"
                id="search-dd-input"
                class="search-dd-input"
                placeholder={t('header.searchPlaceholder')}
                autocomplete="off"
              />
              <span class="search-dd-spinner" id="search-dd-spinner"></span>
            </div>
            <div id="search-dd-body" class="search-dd-body"></div>
          </div>
        </div>

        <div class="theme-switcher">
          <button
            id="theme-toggle"
            class="action-btn"
            aria-label={t('header.toggleTheme')}
            aria-haspopup="true"
          >
            <span class="theme-icon" set:html={uiIcons.palette} />
          </button>
          <div id="theme-dropdown" class="theme-dropdown" role="menu">
            <div class="theme-dropdown-header">{t('header.selectTheme')}</div>
            {
              THEME_METAS.map((theme) => (
                <button
                  class="theme-option"
                  data-theme-name={theme.id}
                  style={`--theme-color: ${theme.gradientColor}; --theme-tint: ${theme.accentColor}; --theme-border: color-mix(in srgb, ${theme.accentColor} 45%, transparent);`}
                  role="menuitem"
                >
                  <span class="theme-preview" />
                  <span class="theme-name">{theme.name}</span>
                  <span class="theme-check">✓</span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="notif-area" id="notif-area" style="display: none;">
          <NotificationBell client:idle i18n={notifI18n} />
        </div>

        <div class="user-area" id="user-area">
          <button class="login-btn" id="header-login-btn" aria-label={t('header.login')}>
            <span class="login-icon" set:html={uiIcons.githubLogin} />
            <span class="login-text">{t('header.login')}</span>
          </button>
          <div class="user-menu" id="header-user-menu" style="display: none;">
            <button
              class="user-avatar-btn"
              id="user-avatar-btn"
              aria-label="用户菜单"
              aria-haspopup="true"
            >
              <img
                id="header-user-avatar"
                class="user-avatar"
                src=""
                alt=""
                width="32"
                height="32"
              />
            </button>
          </div>
          <div class="login-dropdown" id="login-dropdown" role="menu">
            <div id="login-dd-not-logged" class="login-dd-state">
              <p class="login-dd-desc">{t('header.loginDesc')}</p>
              <a id="login-dd-github-btn" href="#" class="login-dd-github-btn">
                <span class="login-dd-gh-icon" set:html={uiIcons.githubLogin} />
                <span>{t('header.loginWithGithub')}</span>
              </a>
            </div>
            <div id="login-dd-logged" class="login-dd-state" style="display:none;">
              <div class="login-dd-user-row">
                <img
                  id="login-dd-avatar"
                  class="login-dd-avatar"
                  src=""
                  alt=""
                  width="36"
                  height="36"
                />
                <div class="login-dd-user-info">
                  <span id="login-dd-username" class="login-dd-username"></span>
                  <span class="login-dd-badge">{t('header.loggedIn')}</span>
                </div>
              </div>
              <button id="login-dd-logout-btn" class="login-dd-logout" role="menuitem">
                {t('header.logout')}
              </button>
            </div>
          </div>
        </div>

        <div class="mobile-menu-switcher">
          <button
            id="mobile-menu-btn"
            class="action-btn mobile-menu-btn"
            aria-label={t('header.menu')}
            aria-haspopup="true"
          >
            <span set:html={uiIcons.menu} />
          </button>
          <nav id="mobile-nav" class="mobile-nav-dropdown" role="menu">
            {
              navLinks.map((link) => (
                <a href={link.href} class="mobile-nav-link">
                  {link.icon && <span class="nav-icon" set:html={link.icon} />}
                  {link.label}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // 主题切换 + 搜索下拉 + 登录下拉
  import { THEMES, DEFAULT_THEME, type Theme } from '@tsuki/shared/theme'
  import { setTheme as storageSetTheme } from '@/lib/storage'

  interface TsukiWindow extends Window {
    __tsukiHeaderCleanup?: () => void
    __tsukiHeaderBootBound?: boolean
    __tsukiAuthCheckDone?: boolean
    __tsukiCurrentUser?: { login: string; avatar_url: string; profile_url: string } | null
  }

  const tsukiWindow = window as TsukiWindow

  function bindHeaderInteractions() {
    const header = document.querySelector<HTMLElement>('.header')
    const headerTrack = document.querySelector<HTMLElement>('.header-track')
    const banner = document.querySelector<HTMLElement>('.tsuki-banner')

    // i18n strings for search (injected via data attribute)
    const searchI18n = JSON.parse(header?.dataset.searchI18n ?? '{}') as {
      loading: string
      noResults: string
      noTitle: string
      error: string
    }

    const toggle = document.getElementById('theme-toggle')
    const dropdown = document.getElementById('theme-dropdown')
    const themeOptions = document.querySelectorAll<HTMLButtonElement>('.theme-option')
    const mobileMenuBtn = document.getElementById('mobile-menu-btn')
    const mobileNav = document.getElementById('mobile-nav')

    // Search dropdown elements
    const searchToggle = document.getElementById('search-toggle')
    const searchDropdown = document.getElementById('search-dropdown')
    const searchInput = document.getElementById('search-dd-input') as HTMLInputElement | null
    const searchBody = document.getElementById('search-dd-body')
    const searchSpinner = document.getElementById('search-dd-spinner')

    // Login dropdown elements
    const loginBtn = document.getElementById('header-login-btn')
    const loginDropdown = document.getElementById('login-dropdown')
    const userAvatarBtn = document.getElementById('user-avatar-btn')

    if (!header || !headerTrack) {
      return () => {}
    }
    const headerEl = header

    const controller = new AbortController()
    const signal = controller.signal

    // ── Pagefind ──
    let pf: any = null
    let searchTimer: ReturnType<typeof setTimeout>
    let searchIdx = -1
    let searchItems: HTMLAnchorElement[] = []

    // Idle-time preload: load pagefind index before user searches
    function preloadPagefind() {
      if (pf) return
      const load = new Function("return import('/pagefind/pagefind.js')")
      load()
        .then((m: any) => {
          pf = m
          pf.init()
        })
        .catch(() => {})
    }
    if ('requestIdleCallback' in window) {
      requestIdleCallback(preloadPagefind, { timeout: 4000 })
    } else {
      setTimeout(preloadPagefind, 2000)
    }

    function resetSearchResults() {
      searchIdx = -1
      searchItems = []
    }

    function highlightSearch() {
      searchItems.forEach((el, i) => el.classList.toggle('is-active', i === searchIdx))
      if (searchIdx >= 0 && searchItems[searchIdx])
        searchItems[searchIdx]!.scrollIntoView({ block: 'nearest' })
    }

    async function doSearch(q: string) {
      if (!searchBody || !searchSpinner) return
      try {
        if (!pf) {
          // Show loading message while pagefind loads
          searchBody.innerHTML =
            '<div class="search-dd-loading"><span class="search-dd-spinner on"></span> ' +
            searchI18n.loading +
            '</div>'
          const load = new Function("return import('/pagefind/pagefind.js')")
          pf = await load()
          await pf.init()
        }
        pf.preload(q)
        const res = await pf.search(q)
        searchSpinner.classList.remove('on')

        if (!res.results.length) {
          searchBody.innerHTML = '<div class="search-dd-nil">' + searchI18n.noResults + '</div>'
          resetSearchResults()
          return
        }

        const data = await Promise.all(res.results.slice(0, 8).map((r: any) => r.data()))

        searchBody.innerHTML = data
          .map(
            (d: any) =>
              `<a href="${d.url}" class="sr-item" data-sr>` +
              `<span class="sr-title">${d.meta?.title || searchI18n.noTitle}</span>` +
              (d.excerpt ? `<span class="sr-excerpt">${d.excerpt}</span>` : '') +
              `</a>`
          )
          .join('')

        searchItems = Array.from(searchBody.querySelectorAll('[data-sr]'))
        searchIdx = -1

        searchItems.forEach((el, i) => {
          el.addEventListener('click', () => closeAllDropdowns())
          el.addEventListener('mouseenter', () => {
            searchIdx = i
            highlightSearch()
          })
        })
      } catch {
        if (searchSpinner) searchSpinner.classList.remove('on')
        if (searchBody) {
          searchBody.innerHTML = '<div class="search-dd-nil">' + searchI18n.error + '</div>'
          resetSearchResults()
        }
      }
    }

    // ── Theme ──
    function getCurrentTheme(): Theme {
      const theme = document.documentElement.getAttribute('data-theme')
      return THEMES.includes(theme as Theme) ? (theme as Theme) : DEFAULT_THEME
    }

    function setTheme(theme: Theme) {
      document.documentElement.setAttribute('data-theme', theme)
      storageSetTheme(theme)
      updateActiveTheme()
    }

    function updateActiveTheme() {
      const current = getCurrentTheme()
      themeOptions.forEach((option) => {
        const isActive = option.getAttribute('data-theme-name') === current
        option.classList.toggle('active', isActive)
      })
    }

    // ── Close all dropdowns ──
    function closeAllDropdowns() {
      dropdown?.classList.remove('open')
      mobileNav?.classList.remove('open')
      searchDropdown?.classList.remove('open')
      loginDropdown?.classList.remove('open')
    }

    function updateHeaderState() {
      const scrollTop = window.scrollY
      const isScrolled = scrollTop > 8
      headerEl.classList.toggle('scrolled', isScrolled)

      if (!banner) return

      const threshold = banner.offsetHeight - 88
      const inMain = scrollTop >= threshold
      const inMainApproach = scrollTop >= threshold - 40
      headerEl.classList.toggle('in-main-approach', inMainApproach)
      headerEl.classList.toggle('in-main', inMain)
      if (inMainApproach) {
        closeAllDropdowns()
      }
    }

    // ── Theme toggle ──
    toggle?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        const wasOpen = dropdown?.classList.contains('open')
        closeAllDropdowns()
        if (!wasOpen) dropdown?.classList.add('open')
      },
      { signal }
    )

    themeOptions.forEach((option) => {
      option.addEventListener(
        'click',
        () => {
          const theme = option.getAttribute('data-theme-name') as Theme
          if (theme && THEMES.includes(theme)) {
            setTheme(theme)
            dropdown?.classList.remove('open')
          }
        },
        { signal }
      )
    })

    // ── Mobile menu ──
    mobileMenuBtn?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        const wasOpen = mobileNav?.classList.contains('open')
        closeAllDropdowns()
        if (!wasOpen) mobileNav?.classList.add('open')
      },
      { signal }
    )

    // ── Search toggle ──
    searchToggle?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        const wasOpen = searchDropdown?.classList.contains('open')
        closeAllDropdowns()
        if (!wasOpen) {
          searchDropdown?.classList.add('open')
          requestAnimationFrame(() => searchInput?.focus())
        }
      },
      { signal }
    )

    // Search input
    searchInput?.addEventListener(
      'input',
      () => {
        clearTimeout(searchTimer)
        const q = searchInput.value.trim()
        if (!q) {
          searchSpinner?.classList.remove('on')
          if (searchBody) searchBody.innerHTML = ''
          resetSearchResults()
          return
        }
        searchSpinner?.classList.add('on')
        searchTimer = setTimeout(() => doSearch(q), 180)
      },
      { signal }
    )

    // Search keyboard navigation
    searchDropdown?.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          closeAllDropdowns()
          return
        }
        if (!searchItems.length) return
        if (e.key === 'ArrowDown') {
          e.preventDefault()
          searchIdx = (searchIdx + 1) % searchItems.length
          highlightSearch()
        } else if (e.key === 'ArrowUp') {
          e.preventDefault()
          searchIdx = searchIdx <= 0 ? searchItems.length - 1 : searchIdx - 1
          highlightSearch()
        } else if (e.key === 'Enter' && searchIdx >= 0 && searchItems[searchIdx]?.href) {
          e.preventDefault()
          closeAllDropdowns()
          window.location.href = searchItems[searchIdx]!.href
        }
      },
      { signal }
    )

    // ── Login / User dropdown ──
    function openLoginDropdown() {
      const wasOpen = loginDropdown?.classList.contains('open')
      closeAllDropdowns()
      if (wasOpen) return

      // Update login state
      const user = tsukiWindow.__tsukiCurrentUser
      const loggedEl = document.getElementById('login-dd-logged')
      const notLoggedEl = document.getElementById('login-dd-not-logged')
      const avatar = document.getElementById('login-dd-avatar') as HTMLImageElement | null
      const username = document.getElementById('login-dd-username')
      const githubBtn = document.getElementById('login-dd-github-btn') as HTMLAnchorElement | null

      if (githubBtn) {
        const returnTo = encodeURIComponent(window.location.pathname)
        githubBtn.href = `${AUTH_API_BASE}/auth/github/start?return_to=${returnTo}`
      }

      if (user && loggedEl && notLoggedEl) {
        notLoggedEl.style.display = 'none'
        loggedEl.style.display = 'block'
        if (avatar) {
          avatar.src = user.avatar_url
          avatar.alt = user.login
        }
        if (username) username.textContent = user.login
      } else if (loggedEl && notLoggedEl) {
        notLoggedEl.style.display = 'block'
        loggedEl.style.display = 'none'
      }

      loginDropdown?.classList.add('open')
    }

    loginBtn?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        openLoginDropdown()
      },
      { signal }
    )

    userAvatarBtn?.addEventListener(
      'click',
      (e) => {
        e.stopPropagation()
        openLoginDropdown()
      },
      { signal }
    )

    // Custom event for React comment area
    window.addEventListener('tsuki:open-login', () => openLoginDropdown(), { signal })

    // Logout
    const logoutBtn = document.getElementById('login-dd-logout-btn')
    logoutBtn?.addEventListener(
      'click',
      async () => {
        try {
          await fetch(`${AUTH_API_BASE}/auth/logout`, {
            method: 'POST',
            credentials: 'include',
          })
        } catch {
          // Ignore
        }
        tsukiWindow.__tsukiCurrentUser = null
        tsukiWindow.__tsukiAuthCheckDone = false
        loginDropdown?.classList.remove('open')
        applyAuthState()
      },
      { signal }
    )

    // Ctrl+K / Cmd+K
    document.addEventListener(
      'keydown',
      (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault()
          if (searchDropdown?.classList.contains('open')) {
            closeAllDropdowns()
          } else {
            closeAllDropdowns()
            searchDropdown?.classList.add('open')
            requestAnimationFrame(() => searchInput?.focus())
          }
        }
      },
      { signal }
    )

    // ── Click outside / Escape ──
    document.addEventListener(
      'click',
      (e) => {
        const target = e.target as Node
        // Check if click is outside all dropdowns
        const inDropdown =
          dropdown?.contains(target) ||
          target === toggle ||
          mobileNav?.contains(target) ||
          target === mobileMenuBtn ||
          searchDropdown?.contains(target) ||
          target === searchToggle ||
          loginDropdown?.contains(target) ||
          target === loginBtn ||
          target === userAvatarBtn
        if (!inDropdown) {
          closeAllDropdowns()
        }
      },
      { signal }
    )

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          closeAllDropdowns()
        }
      },
      { signal }
    )

    updateHeaderState()
    window.addEventListener('scroll', updateHeaderState, { passive: true, signal })
    window.addEventListener('resize', updateHeaderState, { passive: true, signal })
    updateActiveTheme()

    return () => controller.abort()
  }

  function bootHeaderInteractions() {
    tsukiWindow.__tsukiHeaderCleanup?.()
    tsukiWindow.__tsukiHeaderCleanup = bindHeaderInteractions()
  }

  if (!tsukiWindow.__tsukiHeaderBootBound) {
    document.addEventListener('astro:page-load', bootHeaderInteractions)
    tsukiWindow.__tsukiHeaderBootBound = true
  }

  bootHeaderInteractions()

  // Auth state detection
  const AUTH_API_BASE = import.meta.env.PUBLIC_TSUKI_API_BASE || 'http://localhost:8787/v1'

  function applyAuthState() {
    const user = tsukiWindow.__tsukiCurrentUser
    const loginBtn = document.getElementById('header-login-btn')
    const userMenu = document.getElementById('header-user-menu')
    const avatar = document.getElementById('header-user-avatar') as HTMLImageElement | null
    const notifArea = document.getElementById('notif-area')

    if (!loginBtn || !userMenu) return

    if (user) {
      loginBtn.style.display = 'none'
      userMenu.style.display = 'block'
      if (notifArea) notifArea.style.display = ''
      if (avatar) {
        avatar.src = user.avatar_url
        avatar.alt = user.login
      }
    } else {
      loginBtn.style.display = ''
      userMenu.style.display = 'none'
      if (notifArea) notifArea.style.display = 'none'
    }
  }

  async function checkAuthState() {
    if (tsukiWindow.__tsukiAuthCheckDone) {
      applyAuthState()
      return
    }

    try {
      const res = await fetch(`${AUTH_API_BASE}/auth/me`, { credentials: 'include' })
      if (res.ok) {
        const result = await res.json()
        if (result.ok && result.data) {
          tsukiWindow.__tsukiCurrentUser = {
            login: result.data.login,
            avatar_url: result.data.avatar_url,
            profile_url: result.data.profile_url,
          }
        } else {
          tsukiWindow.__tsukiCurrentUser = null
        }
      } else {
        tsukiWindow.__tsukiCurrentUser = null
      }
    } catch {
      tsukiWindow.__tsukiCurrentUser = null
    }

    tsukiWindow.__tsukiAuthCheckDone = true
    applyAuthState()
  }

  checkAuthState()
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    --tsuki-header-collapse-offset: -78px;
    --tsuki-header-track-duration: 220ms;
    transition:
      background-color 150ms,
      opacity 150ms cubic-bezier(0.4, 0, 0.2, 1),
      transform 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .header-inner {
    width: 100%;
    margin: 0 auto;
    padding-block: var(--tsuki-header-inner-padding-block);
    padding-inline: clamp(10px, 1.4vw, 24px);
    position: relative;
  }

  .header-track {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(1.1rem, 3vw, 2.4rem);
    position: relative;
    margin-top: calc(
      -1 * (var(--tsuki-header-frame-top-gap) + var(--tsuki-header-frame-top-overflow))
    );
    margin-inline: 0;
    padding: calc(var(--tsuki-header-frame-top-gap) + var(--tsuki-header-frame-top-overflow))
      var(--tsuki-header-frame-side-gap) var(--tsuki-header-frame-bottom-gap);
    border-radius: var(--tsuki-header-frame-radius);
    --tsuki-header-track-shift-y: 0px;
    transform: translateY(var(--tsuki-header-track-shift-y));
    transition:
      transform var(--tsuki-header-track-duration) linear,
      background-color 160ms ease-out,
      border-color 160ms ease-out,
      box-shadow 160ms ease-out;
  }

  @media (min-width: 1600px) {
    .header-track {
      margin-inline: calc((100% + 3 * var(--tsuki-sidebar-gap)) / 7);
    }
  }

  .header.scrolled .header-track {
    background: var(--tsuki-header-frame-bg);
    border-color: var(--tsuki-header-frame-border);
    box-shadow: var(--tsuki-header-frame-shadow);
  }

  .header-pill {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    height: var(--tsuki-header-pill-height);
    padding: 0 1.35rem;
    border-radius: 999px;
    background: var(--tsuki-header-pill-bg);
    border: 1px solid var(--tsuki-header-track-border);
    box-shadow: var(--tsuki-shadow-header);
    transition:
      background-color 150ms,
      border-color 150ms,
      box-shadow 150ms;
    position: relative;
    z-index: 1;
  }

  .mobile-menu-btn {
    position: relative;
    z-index: 1;
  }

  .header-brand {
    padding: 0 1.45rem;
    justify-self: start;
    transform: translateY(0);
    transition: transform 220ms ease-out;
  }

  .nav {
    display: flex;
    flex: 0 0 auto;
    justify-content: center;
    gap: 1.4rem;
    padding: 0 1.9rem;
    margin-inline: var(--tsuki-header-center-safe-inline);
    justify-self: center;
    transform: translateY(var(--tsuki-header-center-pill-shift-y));
    transition: transform 220ms ease-out;
  }

  .header.in-main {
    opacity: 0;
    transform: translateY(-4rem);
    pointer-events: none;
  }

  .header.in-main .theme-dropdown,
  .header.in-main .mobile-nav-dropdown,
  .header.in-main .search-dropdown,
  .header.in-main .login-dropdown {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px) scale(0.96);
    pointer-events: none;
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0 1.15rem;
    justify-self: end;
    position: relative;
