# Ignore everything by default
*

# ── Project source ──────────────────────────
!apps/
!apps/**
!services/
!services/**
!packages/
!packages/**
!migrations/
!migrations/**
!contents/
!contents/**

# ── Exclude common dirs ─────────────────────
**/node_modules/
**/.astro/
**/.wrangler/
**/.dev.vars

# ── Root config ─────────────────────────────
!.gitignore
!.prettierrc
!eslint.config.mjs
!package.json
!bun.lock
!tsconfig.base.json
!tsconfig.json
!tsuki.config.json
!README.md
!README.zh-CN.md

# ── CI / Tooling ───────────────────────────
!.github/
!.github/**

# Generated image optimization artifacts
contents/.tsuki-avif/
